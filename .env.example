# Runtime
PORT=7860
FLASK_ENV=production
APP_ENV=local
LOG_LEVEL=INFO

# Gemini generation
# Create a fresh key at https://aistudio.google.com/apikey
GOOGLE_API_KEY=
GOOGLE_API_KEY_2=
GENAI_MODEL=gemini-2.5-flash

# Retrieval/model settings
EMB_MODEL=AITeamVN/Vietnamese_Embedding
TOP_K=3
SEARCH_LIMIT=10
FAISS_CANDIDATES=50
BM25_CANDIDATES=50

# Data source
# hf: use Hugging Face dataset cache/download.
# local: use DATA_DIR files created by scripts/build_local_index.py.
DATA_SOURCE=hf
HF_REPO_ID=DrPie/eGoV_Data
HF_REPO_TYPE=dataset
HF_LOCAL_FILES_ONLY=false

# Local paths. These are mounted as volumes in docker-compose.yml.
CACHE_DIR=.cache
DATA_DIR=.cache/egov_data
SQLITE_PATH=user_data/egov_bot.db

# Web/API
CORS_ORIGINS=http://localhost:7860,http://127.0.0.1:7860
ENABLE_DEBUG_RETRIEVAL=false
ANSWER_CACHE_TTL_SECONDS=3600
ANSWER_CACHE_MAX_ITEMS=512
